{
  "app": {
    "name": "MyApp",
    "version": "2.1.0",
    "port": 3000,
    "host": "0.0.0.0"
  },
  "database": {
    "url": "postgres://localhost:5432/mydb",
    "maxConnections": 20,
    "ssl": true
  },
  "auth": {
    "jwtSecret": "change-me",
    "tokenExpiry": 3600,
    "refreshExpiry": 86400
  },
  "features": {
    "enableCache": true,
    "enableRateLimit": false,
    "maxRequestsPerMinute": 100
  }
}

{
  "name": "bosun",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "bosun": "./scripts/onboard.sh"
  },
  "description": "Bosun — personal multi-agent Pi coding environment",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "init": "bun run scripts/init.ts",
    "test": "bun test packages/",
    "postinstall": "cd node_modules/@tobilu/qmd && [ -d dist ] || bun run build"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "0.61.0",
    "@tobilu/qmd": "github:tobi/qmd#v2.0.1",
    "pi-mcp-adapter": "2.1.2",
    "pi-mesh": "0.2.1",
    "pi-web-access": "0.10.2"
  },
  "devDependencies": {
    "@iarna/toml": "3.0.0",
    "@types/bun": "latest"
  },
  "overrides": {
    "@mozilla/readability": "0.6.0"
  }
}

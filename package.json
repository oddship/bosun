{
  "name": "bosun",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Bosun — personal multi-agent Pi coding environment",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "init": "bun run scripts/init.ts",
    "postinstall": "cd node_modules/@tobilu/qmd && [ -d dist ] || bun run build"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.58.4",
    "@tobilu/qmd": "github:tobi/qmd#v2.0.1",
    "pi-agents": "workspace:*",
    "pi-auto-resume": "workspace:*",
    "pi-bash-readonly": "workspace:*",
    "pi-daemon": "workspace:*",
    "pi-mcp-adapter": "^2.1.2",
    "pi-memory": "workspace:*",
    "pi-mesh": "^0.2.0",
    "pi-meta-skills": "workspace:*",
    "pi-q": "workspace:*",
    "pi-question": "workspace:*",
    "pi-sandbox": "workspace:*",
    "pi-session-context": "workspace:*",
    "pi-tmux": "workspace:*",
    "pi-web-access": "^0.10.2"
  },
  "devDependencies": {
    "@iarna/toml": "^3.0.0",
    "@types/bun": "latest"
  },
  "overrides": {
    "@mozilla/readability": "^0.6.0"
  }
}
